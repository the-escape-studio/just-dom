{
  "name": "just-dom",
  "version": "2.0.0",
  "description": "A lightweight library for DOM manipulation",
  "homepage": "https://just-dom.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-escape-studio/just-dom.git",
    "directory": "packages/just-dom"
  },
  "bugs": {
    "url": "https://github.com/the-escape-studio/just-dom/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}