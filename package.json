{
  "name": "just-dom",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "sync:playground-types": "turbo build --filter=just-dom && pnpm --filter site run generate:playground-types",
    "check:playground-types": "pnpm run sync:playground-types && git diff --exit-code -- apps/site/src/views/playground/playground-globals.generated.ts",
    "create:app": "node ./packages/create-just-dom/bin/create-just-dom.mjs",
    "release": "turbo build --filter=just-dom --filter=@just-dom/lucide --filter=@just-dom/router && pnpm --filter site run generate:playground-types && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}