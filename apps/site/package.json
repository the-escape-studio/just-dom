{
  "name": "site",
  "version": "2.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "generate:playground-types": "node ./scripts/generate-playground-types.mjs",
    "dev": "pnpm run generate:playground-types && portless just-dom next dev --turbopack",
    "build": "pnpm run generate:playground-types && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@takumi-rs/image-response": "^1.0.14",
    "@workspace/ui": "workspace:*",
    "emmet-monaco-es": "^5.7.0",
    "fumadocs-core": "16.7.16",
    "fumadocs-mdx": "14.3.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@latest",
    "@just-dom/lucide": "workspace:*",
    "@just-dom/router": "workspace:*",
    "just-dom": "workspace:*",
    "lucide": "^0.577.0",
    "lucide-react": "^1.8.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  }
}