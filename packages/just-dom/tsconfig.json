{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es2017",
    "module": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "emitDeclarationOnly": true,
    "moduleResolution": "NodeNext",
    "isolatedModules": true
  },
  "include": ["src/**/*.js", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
