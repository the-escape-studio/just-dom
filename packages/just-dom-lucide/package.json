{
  "name": "just-dom-lucide",
  "version": "1.0.0",
  "description": "Lucide icons plugin for just-dom",
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts"
  },
  "peerDependencies": {
    "just-dom": ">=1.0.0"
  },
  "dependencies": {
    "lucide": "^0.577.0"
  },
  "devDependencies": {
    "just-dom": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
